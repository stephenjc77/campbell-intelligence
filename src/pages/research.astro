---
const recentResearch = [
  {
    type: "Research Note 002",
    category: "Artificial Intelligence",
    title: "The Intelligence Implications of Autonomous Systems",
    description:
      "How agentic systems may change intelligence collection, analysis, attribution, and operational decision-making.",
    date: "Forthcoming",
    readTime: "Research preview",
  },
  {
    type: "Research Note 003",
    category: "Strategic Analysis",
    title: "Signals in the Noise",
    description:
      "A framework for separating meaningful changes in the security environment from temporary technical activity.",
    date: "Forthcoming",
    readTime: "Research preview",
  },
  {
    type: "Technical Brief 001",
    category: "Infrastructure Analysis",
    title: "Understanding Adversary Infrastructure as a System",
    description:
      "Why individual indicators matter less than the relationships between hosting, certificates, communications, and operational behavior.",
    date: "Forthcoming",
    readTime: "Research preview",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta
      name="description"
      content="Campbell Intelligence publishes independent research on threat infrastructure, artificial intelligence, technical investigations, and strategic risk."
    />

    <title>Campbell Intelligence</title>
  </head>

  <body>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="Campbell Intelligence home">
        Campbell Intelligence
      </a>

      <nav aria-label="Primary navigation">
        <a href="/research">Research</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="publication-intro">
        <div class="publication-name">
          <p>Independent intelligence research</p>
          <h1>Campbell Intelligence</h1>
        </div>

        <div class="publication-description">
          <p>
            Research on threat infrastructure, artificial intelligence,
            technical investigations, and strategic risk.
          </p>

          <a href="/research">
            View all research
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>

      <section class="featured-research">
        <div class="section-label">
          <span>Featured investigation</span>
          <span>Research Note 001</span>
        </div>

        <div class="featured-grid">
          <div class="featured-title">
            <p class="category">Threat infrastructure</p>

            <h2>
              Mapping the Infrastructure Behind Modern Cyber Operations
            </h2>
          </div>

          <div class="featured-summary">
            <p class="dek">
              An infrastructure-first examination of how adversaries deploy,
              rotate, conceal, and reuse operational systems.
            </p>

            <p>
              The research moves beyond isolated indicators to examine the
              relationships between hosting providers, certificates, network
              communications, services, and observable infrastructure
              behavior.
            </p>

            <div class="article-details">
              <span>Forthcoming</span>
              <span>Technical investigation</span>
            </div>

            <a class="read-link" href="/research">
              Read the research preview
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </section>

      <section class="latest-research">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Latest research</p>
            <h2>Research notes and analysis</h2>
          </div>

          <p>
            Independent technical research written for practitioners,
            researchers, and decision-makers.
          </p>
        </div>

        <div class="research-list">
          {
            recentResearch.map((item, index) => (
              <article>
                <span class="research-number">
                  {String(index + 2).padStart(2, "0")}
                </span>

                <div class="research-content">
                  <div class="research-meta">
                    <span>{item.type}</span>
                    <span>{item.category}</span>
                  </div>

                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>

                <div class="research-status">
                  <span>{item.date}</span>
                  <span>{item.readTime}</span>
                </div>
              </article>
            ))
          }
        </div>

        <a class="archive-link" href="/research">
          Explore the research archive
          <span aria-hidden="true">→</span>
        </a>
      </section>

      <section class="research-areas">
        <div class="section-label">
          <span>Research areas</span>
          <span>Current focus</span>
        </div>

        <div class="area-grid">
          <div>
            <span>01</span>
            <h3>Threat Infrastructure</h3>
            <p>
              Research into the systems, providers, communications, and
              technical dependencies supporting cyber operations.
            </p>
          </div>

          <div>
            <span>02</span>
            <h3>Artificial Intelligence</h3>
            <p>
              Analysis of how emerging AI systems affect intelligence,
              security, decision-making, and operational risk.
            </p>
          </div>

          <div>
            <span>03</span>
            <h3>Strategic Analysis</h3>
            <p>
              Evidence-based interpretation of technical developments and
              their broader strategic consequences.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section" id="about">
        <p class="eyebrow">About Campbell Intelligence</p>

        <div class="about-grid">
          <h2>
            Intelligence should illuminate reality, not merely describe
            activity.
          </h2>

          <div>
            <p>
              Campbell Intelligence is an independent research organization
              examining the systems, technologies, and strategic forces
              shaping the modern security environment.
            </p>

            <p>
              The work combines technical evidence, infrastructure analysis,
              and clear strategic judgment. The objective is not more
              information. It is better understanding.
            </p>
          </div>
        </div>
      </section>

      <section class="contact-section" id="contact">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Research inquiries and collaboration.</h2>
        </div>

        <p>
          Contact information will be available when Campbell Intelligence
          formally launches.
        </p>
      </section>
    </main>

    <footer>
      <a class="wordmark" href="/">Campbell Intelligence</a>
      <p>Independent research and strategic analysis.</p>
      <p>© {new Date().getFullYear()} Campbell Intelligence</p>
    </footer>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Libre+Caslon+Display&display=swap");

  :root {
    --navy: #081521;
    --navy-soft: #102231;
    --paper: #f2efe7;
    --paper-dark: #e7e2d7;
    --gold: #9d7d43;
    --muted: #626b6d;
    --line: rgba(8, 21, 33, 0.18);
    --dark-line: rgba(242, 239, 231, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--navy);
    font-family: "DM Sans", sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3,
  .wordmark {
    font-family: "Libre Caslon Display", Georgia, serif;
    font-weight: 400;
  }

  .site-header {
    min-height: 92px;
    padding: 0 5vw;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--navy);
    color: var(--paper);
    border-bottom: 1px solid var(--dark-line);
  }

  .wordmark {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    gap: clamp(1rem, 3vw, 2.5rem);
  }

  nav a {
    color: rgba(242, 239, 231, 0.7);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  nav a:hover {
    color: var(--paper);
  }

  .publication-intro {
    min-height: 430px;
    padding: 85px 5vw 70px;
    display: grid;
    grid-template-columns: 1.6fr 0.7fr;
    gap: 8vw;
    align-items: end;
    border-bottom: 1px solid var(--line);
  }

  .publication-name > p,
  .eyebrow,
  .category {
    margin-bottom: 22px;
    color: var(--gold);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h1 {
    margin-bottom: 0;
    font-size: clamp(4.5rem, 10vw, 9.5rem);
    line-height: 0.88;
    letter-spacing: -0.065em;
  }

  .publication-description {
    padding-bottom: 10px;
  }

  .publication-description p {
    color: var(--muted);
    font-family: "Libre Caslon Display", Georgia, serif;
    font-size: clamp(1.35rem, 2.3vw, 2.1rem);
    line-height: 1.25;
  }

  .publication-description a,
  .read-link,
  .archive-link {
    width: fit-content;
    padding-bottom: 6px;
    display: flex;
    gap: 12px;
    align-items: center;
    border-bottom: 1px solid var(--gold);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .featured-research {
    padding: 35px 5vw 100px;
  }

  .section-label {
    padding-bottom: 20px;
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .featured-grid {
    padding-top: 65px;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: 9vw;
  }

  .featured-title h2 {
    max-width: 900px;
    margin-bottom: 0;
    font-size: clamp(3.4rem, 6.8vw, 7rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .featured-summary {
    padding-top: 41px;
  }

  .featured-summary .dek {
    color: var(--navy);
    font-family: "Libre Caslon Display", Georgia, serif;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    line-height: 1.3;
  }

  .featured-summary > p:not(.dek) {
    color: var(--muted);
  }

  .article-details {
    margin: 38px 0;
    padding: 17px 0;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    color: var(--muted);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .latest-research {
    padding: 100px 5vw;
    background: var(--navy);
    color: var(--paper);
  }

  .section-heading {
    margin-bottom: 65px;
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 10vw;
    align-items: end;
  }

  .section-heading h2,
  .about-grid h2,
  .contact-section h2 {
    margin-bottom: 0;
    font-size: clamp(2.8rem, 5vw, 5.2rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .section-heading > p {
    margin-bottom: 5px;
    color: rgba(242, 239, 231, 0.58);
  }

  .research-list {
    border-top: 1px solid var(--dark-line);
  }

  article {
    min-height: 265px;
    padding: 42px 0;
    display: grid;
    grid-template-columns: 70px 1fr 190px;
    gap: 35px;
    border-bottom: 1px solid var(--dark-line);
  }

  .research-number {
    color: var(--gold);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .research-meta {
    margin-bottom: 25px;
    display: flex;
    gap: 30px;
    color: rgba(242, 239, 231, 0.5);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  article h3 {
    max-width: 790px;
    margin-bottom: 18px;
    font-size: clamp(2rem, 3.7vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  article p {
    max-width: 650px;
    margin-bottom: 0;
    color: rgba(242, 239, 231, 0.58);
  }

  .research-status {
    display: flex;
    flex-direction: column;
    gap: 9px;
    color: rgba(242, 239, 231, 0.45);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-link {
    margin-top: 45px;
  }

  .research-areas {
    padding: 35px 5vw 110px;
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .area-grid > div {
    min-height: 330px;
    padding: 55px 38px 25px;
    border-right: 1px solid var(--line);
  }

  .area-grid > div:first-child {
    padding-left: 0;
  }

  .area-grid > div:last-child {
    border-right: 0;
  }

  .area-grid span {
    color: var(--gold);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .area-grid h3 {
    margin: 70px 0 20px;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .area-grid p {
    color: var(--muted);
  }

  .about-section {
    padding: 110px 5vw;
    background: var(--paper-dark);
    border-top: 1px solid var(--line);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: 10vw;
  }

  .about-grid > div {
    padding-top: 15px;
    color: #475154;
    font-size: 1.04rem;
  }

  .contact-section {
    padding: 100px 5vw;
    display: grid;
    grid-template-columns: 1.5fr 0.5fr;
    gap: 10vw;
    align-items: end;
    background: var(--navy-soft);
    color: var(--paper);
  }

  .contact-section > p {
    color: rgba(242, 239, 231, 0.55);
  }

  footer {
    min-height: 165px;
    padding: 42px 5vw;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: end;
    background: var(--navy);
    color: var(--paper);
    border-top: 1px solid var(--dark-line);
  }

  footer p {
    margin-bottom: 0;
    color: rgba(242, 239, 231, 0.45);
    font-size: 0.7rem;
  }

  footer p:last-child {
    text-align: right;
  }

  @media (max-width: 850px) {
    .site-header {
      padding-top: 24px;
      padding-bottom: 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    nav {
      width: 100%;
      justify-content: space-between;
    }

    .publication-intro,
    .featured-grid,
    .section-heading,
    .about-grid,
    .contact-section,
    footer {
      grid-template-columns: 1fr;
    }

    .publication-intro {
      min-height: auto;
      padding-top: 70px;
      gap: 55px;
    }

    h1 {
      font-size: clamp(4rem, 17vw, 7rem);
    }

    .featured-grid {
      gap: 25px;
    }

    .featured-summary {
      padding-top: 0;
    }

    article {
      grid-template-columns: 45px 1fr;
    }

    .research-status {
      display: none;
    }

    .area-grid {
      grid-template-columns: 1fr;
    }

    .area-grid > div,
    .area-grid > div:first-child {
      min-height: auto;
      padding: 45px 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .area-grid h3 {
      margin-top: 40px;
    }

    footer {
      gap: 18px;
    }

    footer p:last-child {
      text-align: left;
    }
  }

  @media (max-width: 520px) {
    .publication-intro {
      padding-bottom: 55px;
    }

    .featured-research,
    .latest-research,
    .research-areas,
    .about-section,
    .contact-section {
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .section-label {
      gap: 15px;
    }

    article {
      grid-template-columns: 30px 1fr;
      gap: 15px;
    }

    .research-meta {
      flex-direction: column;
      gap: 7px;
    }
  }
</style>